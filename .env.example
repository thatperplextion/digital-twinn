# ============================================
# Digital Twin Platform - Environment Template
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git!
# ============================================

# PostgreSQL Database
POSTGRES_DB=digitaltwin
POSTGRES_USER=dtuser
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Redis Cache
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# JWT Authentication (min 64 chars)
JWT_SECRET=CHANGE_ME_64_CHARACTER_MINIMUM_SECRET_KEY_FOR_PRODUCTION_USE

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Application Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Environment
SPRING_PROFILES_ACTIVE=production
